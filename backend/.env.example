# Backend
APP_NAME=SignalFeed API
ENVIRONMENT=development
DATABASE_URL=sqlite:///./signalfeed.db
COLLECTION_INTERVAL_MINUTES=15
DEFAULT_MIN_ENGAGEMENT=10
ENABLE_AI_FILTER=false
USE_TWITTER_API=false

# Reddit API
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=signalfeed/0.1 by your-username

# X API (scalable mode)
TWITTER_BEARER_TOKEN=

# Optional OpenAI-compatible API for AI categorization
LLM_API_KEY=
LLM_API_URL=
LLM_MODEL=gpt-4o-mini

# Telegram (optional, backend-triggered alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
